generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blogs blog[]
}

enum blogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model blog {
  id String @id @default(uuid())

  title String
  slug  String @unique

  excerpt String?
  content String  @db.Text

  thumbnail  String?
  coverImage String?

  category String?
  tags     Json?

  metaTitle       String?
  metaDescription String?
  keywords        String?

  featured Boolean @default(false)

  published Boolean    @default(false)
  status    blogStatus @default(DRAFT)

  publishedAt DateTime?

  views     Int @default(0)
  sortOrder Int @default(0)

  authorId String
  author   admin  @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([category])
}

enum ProjectStatus {
  CONCEPT
  ONGOING
  COMPLETED
}

model ProjectCategory {
  id              String   @id @default(uuid())
  name            String   @unique
  slug            String   @unique
  description     String?
  sortOrder       Int      @default(0)
  image           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subCategories   ProjectSubCategory[]

  @@map("project_categories")
}

model ProjectSubCategory {
  id              String   @id @default(uuid())

  categoryId      String
  category        ProjectCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name            String
  slug            String
  description     String?
  image           String?
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projects        Project[]

  @@unique([categoryId, slug])
  @@map("project_sub_categories")
}

model Project {
  id               String   @id @default(uuid())

  subCategoryId    String
  subCategory      ProjectSubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

  title            String
  slug             String   @unique
  
  shortDescription String?
  description      String? @db.Text

  location         String?
  year             Int?

  clientName       String?
  area             String?

  thumbnail        String?
  coverImage       String?

  status           ProjectStatus?

  featured         Boolean @default(false)
  published        Boolean @default(true)

  metaTitle        String?
  metaDescription  String?
  keywords         String?

  sortOrder        Int      @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  gallery          ProjectGallery[]

  @@map("projects")
}

model ProjectGallery {
  id              String   @id @default(uuid())

  projectId       String
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  image           String

  title           String?
  description     String?

  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("project_galleries")
}

model award {
  id String @id @default(uuid())

  title String
  slug  String @unique

  organization String?
  description  String? @db.Text

  year     Int?
  location String?

  image String?

  featured  Boolean @default(false)
  published Boolean @default(false)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([published])
}

model feature {
  id String @id @default(uuid())

  title String
  slug  String @unique

  description String? @db.Text
  icon        String? // icon class or image URL

  image String?

  category String?

  featured  Boolean @default(false)
  published Boolean @default(false)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([category])
}

enum inquiryStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

model inquiry {
  id          String  @id @default(uuid())
  senderName  String
  senderEmail String
  phone       String?
  projectType String?
  subject     String
  message     String

  status inquiryStatus @default(UNREAD)

  createdAt DateTime @default(now())
}

enum testimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

model testimonial {
  id String @id @default(uuid())

  // Reviewer info
  name    String
  role    String?
  company String?
  avatar  String?

  // Review content
  content String @default("") @db.Text
  rating  Int    @default(5)

  // Admin / CMS controls
  status    testimonialStatus @default(PENDING)
  featured  Boolean           @default(false)
  published Boolean           @default(false)

  sortOrder Int @default(0)

  // SEO / routing (optional but useful)
  slug String @unique

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@index([featured])
  @@index([status])
}
